{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArticleSchema",
  "type": "object",
  "required": [
    "title",
    "author",
    "published_at",
    "source_url",
    "paragraphs",
    "scrape_policy",
    "metadata_only",
    "extraction_status",
    "policy_resolution_failed"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "published_at": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "paragraphs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scrape_policy": {
      "type": "string",
      "enum": [
        "full_scrape_allowed",
        "metadata_only"
      ]
    },
    "metadata_only": {
      "type": "boolean"
    },
    "extraction_status": {
      "type": "string"
    },
    "policy_resolution_failed": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
