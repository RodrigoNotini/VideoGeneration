{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArticleSchema",
  "type": "object",
  "required": [
    "title",
    "author",
    "published_at",
    "source_url",
    "paragraphs"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "published_at": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "paragraphs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
